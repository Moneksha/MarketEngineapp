# Zerodha Kite Connect — get from https://developers.kite.trade/
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_ACCESS_TOKEN=                    # Set after daily login

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/market_engine

# App Settings
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO
MOCK_MODE=false

# Paper Trading
DEFAULT_QUANTITY=75
MARKET_OPEN=09:15
MARKET_CLOSE=15:30
EOD_SQUARE_OFF=15:00

# CORS
FRONTEND_URL=http://localhost:5173

# Email (SMTP) — optional, for strategy request notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
NOTIFY_EMAIL=your_email@gmail.com
